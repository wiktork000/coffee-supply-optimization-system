<mxfile host="65bd71144e">
    <diagram name="Order State Machine" id="0">
        <mxGraphModel dx="335" dy="381" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" background="#ffffff" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="Order — UML state machine (status lifecycle)" style="text;html=1;align=center;fontSize=18;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="20" width="800" height="30" as="geometry"/>
                </mxCell>

                <mxCell id="init" value="" style="ellipse;html=1;shape=startState;fillColor=#000000;strokeColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="120" y="225" width="30" height="30" as="geometry"/>
                </mxCell>

                <mxCell id="st_confirmed" value="confirmed&#xa;&lt;hr size=&quot;1&quot;&gt;entry / persist order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;spacingTop=6;arcSize=20;" parent="1" vertex="1">
                    <mxGeometry x="240" y="200" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="st_shipped" value="shipped" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=30;" parent="1" vertex="1">
                    <mxGeometry x="540" y="210" width="160" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="st_delivered" value="delivered&#xa;&lt;hr size=&quot;1&quot;&gt;entry / increase building inventory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;spacingTop=6;arcSize=20;" parent="1" vertex="1">
                    <mxGeometry x="820" y="195" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="st_cancelled" value="cancelled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=30;" parent="1" vertex="1">
                    <mxGeometry x="560" y="420" width="160" height="60" as="geometry"/>
                </mxCell>

                <mxCell id="final" value="" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1140" y="220" width="30" height="30" as="geometry"/>
                </mxCell>

                <mxCell id="t0" value="POST /orders" style="endArrow=open;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;" parent="1" source="init" target="st_confirmed" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t1" value="PATCH /orders/{id}/status&#xa;[status = shipped]" style="endArrow=open;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;" parent="1" source="st_confirmed" target="st_shipped" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t2" value="PATCH /orders/{id}/status&#xa;[status = delivered]" style="endArrow=open;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;" parent="1" source="st_shipped" target="st_delivered" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t3" value="delivered" style="endArrow=open;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;" parent="1" source="st_delivered" target="final" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t4" value="PATCH /orders/{id}/status&#xa;[status = cancelled]" style="endArrow=open;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" parent="1" source="st_confirmed" target="st_cancelled" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t5" value="PATCH /orders/{id}/status&#xa;[status = cancelled]" style="endArrow=open;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" parent="1" source="st_shipped" target="st_cancelled" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t6" value="" style="endArrow=open;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" parent="1" source="st_cancelled" target="final" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <mxCell id="note_guard" value="Guard on every transition:&#xa;authenticated (Bearer JWT or X-API-Key).&#xa;Transitions correspond to allowed status values&#xa;of PATCH /orders/{id}/status." style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="240" y="560" width="360" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="note_setup" value="Setup data feeding the optimization that proposes these&#xa;orders (admin): buildings.daily_demand, distributor&#xa;daily_prices + discount_tiers. See optimization-workflow." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="820" y="420" width="360" height="90" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
